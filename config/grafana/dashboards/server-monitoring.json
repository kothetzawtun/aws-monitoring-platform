        "sort": 1,
        "current": {
          "text": "",
          "value": ""
        },
        "options": []
      },
      {
        "name": "hostname",
        "type": "query",
        "label": "Host",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(node_uname_info{job=~\"$job\"}, nodename)",
        "definition": "label_values(node_uname_info{job=~\"$job\"}, nodename)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "node",
        "type": "query",
        "label": "Instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(node_uname_info{job=~\"$job\",nodename=~\"$hostname\"},instance)",
        "definition": "label_values(node_uname_info{job=~\"$job\",nodename=~\"$hostname\"},instance)",
        "refresh": 1,
        "includeAll": true,
        "multi": true,
        "allValue": ".+",
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "interval",
        "type": "interval",
        "label": "Interval",
        "query": "30s,1m,2m,3m,5m,10m,30m",
        "refresh": 2,
        "current": {
          "text": "2m",
          "value": "2m"
        },
        "options": [
          {
            "selected": false,
            "text": "30s",
            "value": "30s"
          },
          {
            "selected": false,
