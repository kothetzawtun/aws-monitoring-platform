  "panels": [
    {
      "id": 185,
      "type": "table",
      "title": "Servers Overview",
      "description": "Production server overview for SME infrastructure.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "node_uname_info{job=~\"$job\", instance=~\"$node\"} - 0",
          "format": "table",
          "instant": true,
          "legendFormat": "System Info"
        },
        {
          "refId": "B",
          "expr": "node_memory_MemTotal_bytes{job=~\"$job\", instance=~\"$node\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "Memory"
        },
        {
          "refId": "C",
          "expr": "count(node_cpu_seconds_total{job=~\"$job\", instance=~\"$node\", mode=\"system\"}) by (instance)",
          "format": "table",
          "instant": true,
          "legendFormat": "CPU Cores"
        },
        {
          "refId": "D",
          "expr": "time() - node_boot_time_seconds{job=~\"$job\", instance=~\"$node\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "Uptime"
        },
        {
          "refId": "E",
          "expr": "(1 - avg(rate(node_cpu_seconds_total{job=~\"$job\", instance=~\"$node\", mode=\"idle\"}[$interval])) by (instance)) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "CPU Used"
        },
        {
          "refId": "F",
          "expr": "(1 - (node_memory_MemAvailable_bytes{job=~\"$job\", instance=~\"$node\"} / node_memory_MemTotal_bytes{job=~\"$job\", instance=~\"$node\"})) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "Memory Used"
        },
        {
          "refId": "G",
          "expr": "max by(instance) (100 * (1 - (node_filesystem_avail_bytes{job=~\"$job\", instance=~\"$node\", fstype=~\"ext.*|xfs\"} / node_filesystem_size_bytes{job=~\"$job\", instance=~\"$node\", fstype=~\"ext.*|xfs\"})))",
          "format": "table",
          "instant": true,
          "legendFormat": "Disk Used"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
