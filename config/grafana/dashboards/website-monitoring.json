                  "type": "color-text"
                }
              },
              {
                "id": "thresholds",
                "value": {
                  "mode": "absolute",
                  "steps": [
                    {
                      "color": "red",
                      "value": 0
                    },
                    {
                      "color": "orange",
                      "value": 85
                    },
                    {
                      "color": "yellow",
                      "value": 90
