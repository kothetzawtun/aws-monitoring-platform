{
  "id": null,
  "uid": "website-monitoring",
  "title": "Website Monitoring",
  "tags": [
    "blackbox",
    "website",
    "ssl"
  ],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 4,
  "refresh": "30s",
  "time": {
    "from": "now-7d",
    "to": "now"
  },
  "templating": {
    "list": [
      {
        "name": "job",
        "type": "query",
        "label": "Job",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(probe_success, job)",
        "definition": "label_values(probe_success, job)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".+"
        },
        "options": []
      },
      {
        "name": "instance",
        "type": "query",
        "label": "Instance",
        "datasource": {
          "type": "prometheus",
          "uid": "prometheus"
        },
        "query": "label_values(probe_success{job=~\"$job\"}, instance)",
        "definition": "label_values(probe_success{job=~\"$job\"}, instance)",
        "refresh": 1,
        "includeAll": true,
        "multi": false,
        "allValue": ".+",
        "sort": 1,
        "current": {
          "text": "All",
          "value": ".+"
        },
        "options": []
      }
    ]
  },
  "annotations": {
    "list": [
      {
        "name": "Annotations & Alerts",
        "type": "dashboard",
        "builtIn": 1,
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)"
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "gauge",
      "title": "Overall Uptime",
      "description": "Average success rate of selected Blackbox probes.",
      "gridPos": {
        "x": 0,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg(avg_over_time(probe_success{job=~\"$job\", instance=~\"$instance\"}[$__range]) * 100) or vector(0)",
          "legendFormat": "Uptime",
          "instant": false,
          "range": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "showThresholdLabels": false,
        "showThresholdMarkers": true,
        "textMode": "auto"
      }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Total Websites",
      "gridPos": {
        "x": 8,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(probe_success{job=~\"$job\", instance=~\"$instance\"}) or vector(0)",
          "legendFormat": "Websites",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "value",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Websites Down",
      "gridPos": {
        "x": 16,
        "y": 0,
        "w": 8,
        "h": 7
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "count(probe_success{job=~\"$job\", instance=~\"$instance\"} == 0) or vector(0)",
          "legendFormat": "Down",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 1
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto",
        "orientation": "auto",
        "textMode": "auto"
      }
    },
    {
      "id": 4,
      "type": "timeseries",
      "title": "Website Response Time",
      "gridPos": {
        "x": 0,
        "y": 7,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "probe_duration_seconds{job=~\"$job\", instance=~\"$instance\"}",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "s",
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              },
              {
                "color": "red",
                "value": 5
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "asc"
        }
      }
    },
    {
      "id": 5,
      "type": "timeseries",
      "title": "Overall Availability",
      "gridPos": {
        "x": 0,
        "y": 15,
        "w": 24,
        "h": 8
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=~\"$job\", instance=~\"$instance\"}[$__interval]) * 100",
          "legendFormat": "{{instance}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": 0
              },
              {
                "color": "orange",
                "value": 85
              },
              {
                "color": "yellow",
                "value": 90
              },
              {
                "color": "green",
                "value": 95
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "showLegend": true
        },
        "tooltip": {
          "mode": "multi",
          "sort": "none"
        }
      }
    },
    {
      "id": 6,
      "type": "table",
      "title": "Website Uptime and SSL Expiry Overview",
      "gridPos": {
        "x": 0,
        "y": 23,
        "w": 24,
        "h": 12
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_success{job=~\"$job\", instance=~\"$instance\"}[$__range]) * 100",
          "format": "table",
          "instant": true,
          "legendFormat": "Total Uptime"
        },
        {
          "refId": "B",
          "expr": "(probe_ssl_earliest_cert_expiry{job=~\"$job\", instance=~\"$instance\"} - time()) / 86400",
          "format": "table",
          "instant": true,
          "legendFormat": "SSL Cert Expiry Days"
        },
        {
          "refId": "C",
          "expr": "probe_http_status_code{job=~\"$job\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "HTTP Status"
        },
        {
          "refId": "D",
          "expr": "probe_duration_seconds{job=~\"$job\", instance=~\"$instance\"}",
          "format": "table",
          "instant": true,
          "legendFormat": "Response Time"
        }
      ],
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "organize",
          "options": {
            "excludeByName": {
              "Time": true,
              "Time 1": true,
              "Time 2": true,
              "Time 3": true,
              "Time 4": true,
              "__name__": true,
              "__name__ 1": true,
              "__name__ 2": true,
              "__name__ 3": true,
              "__name__ 4": true,
              "job": true,
              "job 1": true,
              "job 2": true,
              "job 3": true,
              "job 4": true,
              "environment": true,
              "environment 1": true,
              "environment 2": true,
              "environment 3": true,
              "environment 4": true
            },
            "indexByName": {
              "Website": 0,
              "Client Name": 1,
              "Total Uptime": 2,
              "SSL Cert Expiry (days)": 3,
              "HTTP Status": 4,
              "Response Time": 5
            },
            "renameByName": {
              "instance": "Website",
              "instance 1": "Website",
              "client_name": "Client Name",
              "client_name 1": "Client Name",
              "client_name 2": "Client Name",
              "client_name 3": "Client Name",
              "client_name 4": "Client Name",
              "Value #A": "Total Uptime",
              "Value #B": "SSL Cert Expiry (days)",
              "Value #C": "HTTP Status",
              "Value #D": "Response Time"
            }
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "custom": {
            "align": "auto",
            "cellOptions": {
              "type": "auto"
            },
            "filterable": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": 0
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Website"
            },
            "properties": [
              {
                "id": "custom.width",
                "value": 360
              },
              {
                "id": "links",
                "value": [
