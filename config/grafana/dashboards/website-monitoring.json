        ]
      },
      "options": {
        "showHeader": true,
        "cellHeight": "sm"
      }
    },
    {
      "id": 7,
      "type": "table",
      "title": "Response Time Summary",
      "gridPos": {
        "x": 0,
        "y": 35,
        "w": 24,
        "h": 10
      },
      "datasource": {
        "type": "prometheus",
        "uid": "prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "avg_over_time(probe_duration_seconds{job=~\"$job\", instance=~\"$instance\"}[$__range])",
          "format": "table",
          "instant": true,
          "legendFormat": "Mean"
        },
        {
          "refId": "B",
          "expr": "min_over_time(probe_duration_seconds{job=~\"$job\", instance=~\"$instance\"}[$__range])",
          "format": "table",
          "instant": true,
          "legendFormat": "Min"
